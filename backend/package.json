{
  "name": "erp-backend",
  "version": "1.0.0",
  "private": true,
  "description": "API backend for the ERP1 React frontend.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/infrastructure/db/typeorm/run-migrations.js && node dist/server.js",
    "test": "node --import tsx --test test/application.test.ts test/crud.service.test.ts test/purchase-workflow.test.ts test/analytics.service.test.ts",
    "db:migrate": "tsx src/infrastructure/db/typeorm/run-migrations.ts",
    "db:migrate:prod": "node dist/infrastructure/db/typeorm/run-migrations.js",
    "db:seed": "tsx src/infrastructure/db/typeorm/run-seed.ts",
    "db:seed:prod": "node dist/infrastructure/db/typeorm/run-seed.js",
    "typeorm": "tsx ./node_modules/typeorm/cli.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
